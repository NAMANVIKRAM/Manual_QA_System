# --- Embeddings (fully free, no key needed) ---
EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=all-MiniLM-L6-v2   # default; swap for a stronger model if needed

# --- LLM backend: "groq" (default), "ollama" (local), or "huggingface" ---
LLM_PROVIDER=groq
LLM_MODEL=llama3-8b-8192             # groq models: llama3-8b-8192, llama3-70b-8192, mixtral-8x7b-32768

# Groq API key (free at console.groq.com)
GROQ_API_KEY=your-groq-key-here

# HuggingFace Inference API — only needed if LLM_PROVIDER=huggingface
# HF_API_TOKEN=your-hf-token-here
# LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Ollama (local) — only needed if LLM_PROVIDER=ollama
# LLM_MODEL=llama3

# --- Optional overrides ---
# CHROMA_DIR=./chroma_db
# COLLECTION_NAME=nasa_se_handbook
# TOP_K=5
# CHUNK_SIZE=1500
# CHUNK_OVERLAP=150
